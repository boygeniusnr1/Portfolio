---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectsArchiveCard from '../components/ProjectsArchiveCard.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import TechStack from '../components/TechStack.astro';
import SocialsCard from '../components/SocialsCard.astro';
import ContactCard from '../components/ContactCard.astro';
import { siteConfig } from '../data/site-config';
---

<BaseLayout title={siteConfig.title}>
	<main class="bento-grid">
		<Hero delay={100} />
		<ProjectsArchiveCard delay={200} />
		<ExperienceCard delay={300} />
		<TechStack delay={400} />
		<SocialsCard delay={500} />
		<ContactCard delay={600} />
	</main>
</BaseLayout>
