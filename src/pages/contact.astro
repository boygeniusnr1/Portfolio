---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Creative Developer">
	<header class="mb-12 text-center md:text-left">
		<a href="/" class="text-sm font-bold text-neutral-400 uppercase tracking-widest hover:text-brand-primary transition-colors flex items-center justify-center md:justify-start gap-2 mb-4 group">
			<span class="group-hover:-translate-x-1 transition-transform">←</span> Back Home
		</a>
		<h1 class="text-5xl md:text-8xl font-extrabold tracking-tighter">Let's <span class="text-neutral-400 dark:text-neutral-500">Connect.</span></h1>
		<p class="text-xl text-neutral-500 dark:text-neutral-400 max-w-2xl mt-4">Currently open to new opportunities and interesting collaborations.</p>
	</header>

	<main class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
		<!-- Primary Email -->
		<a href="mailto:hello@example.com" class="bento-card col-span-1 flex flex-col justify-between group h-64 border-brand-primary/20 dark:border-brand-primary/10">
			<div class="w-12 h-12 rounded-2xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-6">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
			</div>
			<div>
				<h2 class="text-2xl font-bold mb-2">Email Me</h2>
				<p class="text-neutral-500 dark:text-neutral-400 font-medium">max@m-creates.com</p>
			</div>
		</a>

		<!-- GitHub/Development -->
		<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="bento-card col-span-1 flex flex-col justify-between group h-64">
			<div class="w-12 h-12 rounded-2xl bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center text-neutral-500 dark:text-neutral-400 mb-6 group-hover:text-brand-primary transition-colors">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/></svg>
			</div>
			<div>
				<h2 class="text-2xl font-bold mb-2">GitHub</h2>
				<p class="text-neutral-500 dark:text-neutral-400 font-medium">Open Source & Research</p>
			</div>
		</a>

	</main>
</BaseLayout>
