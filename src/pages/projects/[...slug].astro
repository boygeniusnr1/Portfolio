---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map(project => ({
		params: { slug: project.id }, props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Projects`}>
	<header class="mb-12">
		<a href="/projects" class="text-sm font-bold text-neutral-400 uppercase tracking-widest hover:text-brand-primary transition-colors flex items-center gap-2 mb-4 group">
			<span class="group-hover:-translate-x-1 transition-transform">←</span> Back to Projects
		</a>
		<h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter mb-4">{project.data.title}</h1>
		<p class="text-xl text-neutral-500 dark:text-neutral-400 max-w-2xl">{project.data.description}</p>
	</header>

	<article class="prose prose-neutral dark:prose-invert prose-2xl max-w-4xl prose-headings:font-bold prose-headings:tracking-tighter prose-a:text-brand-primary">
		<Content />
	</article>
</BaseLayout>
