---
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Projects', href: '/projects' },
  { name: 'Contact', href: '/contact' },
];
---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-xl">
  <div class="glass-effect rounded-2xl px-4 md:px-6 py-2 md:py-3 flex items-center justify-between shadow-bento border border-white/20 dark:border-neutral-800/50 bg-white/80 dark:bg-neutral-900/80">
    <a href="/" class="text-base md:text-lg font-black tracking-tighter hover:text-brand-primary transition-colors shrink-0">
      MAX C<span class="text-brand-primary">.</span>
    </a>
    
    <div class="flex items-center gap-4 md:gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-[10px] md:text-sm font-bold text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors uppercase tracking-widest"
        >
          {item.name}
        </a>
      ))}
    </div>

    <div class="hidden sm:flex items-center gap-2 pl-4 border-l border-neutral-200 dark:border-neutral-800">
      <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
      <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-tighter">Live</span>
    </div>
  </div>
</nav>
