---
import BentoCard from './BentoCard.astro';
import { siteConfig } from '../data/site-config';

interface Props {
  delay?: number;
}

const { delay = 0 } = Astro.props;
---

<BentoCard colSpan={4} rowSpan={2} delay={delay} class="justify-end p-6 md:p-8 min-h-80 md:min-h-0">
  <div class="relative z-10">
    <span class="inline-block px-3 py-1 rounded-full bg-brand-primary/10 text-brand-primary text-[10px] md:text-xs font-semibold mb-4 dark:bg-brand-primary/20">
      {siteConfig.author.availability}
    </span>
    <h1 class="text-3xl md:text-7xl font-bold tracking-tight mb-4 leading-[1.1]">
      {siteConfig.heroTitle.main} <span class="text-neutral-400 dark:text-neutral-500">{siteConfig.heroTitle.highlight}</span>
    </h1>
    <p class="text-base md:text-lg text-neutral-500 max-w-md dark:text-neutral-400">
      {siteConfig.description}
    </p>
  </div>
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none dark:opacity-[0.05]" style="background-image: radial-gradient(var(--color-neutral-900) 1px, transparent 1px); background-size: 24px 24px;"></div>
  <div class="absolute inset-0 opacity-0 pointer-events-none dark:opacity-[0.05]" style="background-image: radial-gradient(var(--color-neutral-100) 1px, transparent 1px); background-size: 24px 24px;"></div>
</BentoCard>
