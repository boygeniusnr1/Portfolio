---
import BentoCard from './BentoCard.astro';

interface Props {
  delay?: number;
}

const { delay = 0 } = Astro.props;
---

<BentoCard href="/projects" colSpan={2} rowSpan={3} dark delay={delay} class="items-center justify-center overflow-hidden min-h-[200px] md:min-h-0">
  <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent z-10"></div>
  <div class="z-20 p-8 self-end w-full">
    <p class="text-sm font-mono text-neutral-400 mb-2 tracking-tighter uppercase">View Work</p>
    <h2 class="text-2xl font-bold group-hover:text-brand-primary transition-colors">Projects Archive</h2>
  </div>
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="w-48 h-48 bg-brand-primary/20 blur-3xl rounded-full group-hover:scale-125 transition-transform duration-700"></div>
    <div class="w-32 h-32 border border-white/10 rounded-2xl rotate-45 group-hover:rotate-90 transition-transform duration-700"></div>
  </div>
</BentoCard>
